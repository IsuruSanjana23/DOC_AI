# Application
APP_NAME=DocCollection AI
APP_VERSION=1.0.0
DEBUG=false

# API
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/doccollection

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# LLM (LiteLLM proxy for DeepSeek)
LITELLM_API_KEY=sk-your-litellm-api-key
