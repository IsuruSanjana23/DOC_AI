{
  "info": {
    "name": "DocCollection AI - RAG",
    "description": "Postman collection for testing the RAG chat endpoint",
    "schema": "https://raw.githubusercontent.com/postmanlabs/collections/master/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.collectionVariables.set('token_rag', json.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "username", "value": "your-email@example.com", "type": "text" },
            { "key": "password", "value": "your-password", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "login"]
        }
      }
    },
    {
      "name": "RAG Chat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_rag}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"What is dependency injection in FastAPI?\",\n  \"top_k\": 5,\n  \"min_score\": 0.5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/rag/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "rag", "chat"]
        }
      }
    },
    {
      "name": "RAG Chat - No min_score",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_rag}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"What is dependency injection in FastAPI?\",\n  \"top_k\": 3\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/rag/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "rag", "chat"]
        }
      }
    },
    {
      "name": "RAG Chat - Short query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token_rag}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"Hi\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/rag/chat",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "rag", "chat"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "token_rag",
      "value": ""
    }
  ]
}
